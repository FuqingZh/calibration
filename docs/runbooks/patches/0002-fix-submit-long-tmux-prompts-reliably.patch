From e88f0d89c1b5da5efe808a0f2a144f5e1603b5a7 Mon Sep 17 00:00:00 2001
From: FuqingZhang <103730099+FuqingZh@users.noreply.github.com>
Date: Wed, 22 Jul 2026 20:11:58 +0800
Subject: [PATCH 2/2] fix: submit long tmux prompts reliably

---
 .../adapters/runtime/tmux/commands.go         | 13 ++++++--
 .../internal/adapters/runtime/tmux/tmux.go    | 24 +++++++++++---
 .../adapters/runtime/tmux/tmux_test.go        | 32 ++++++++++++++++++-
 3 files changed, 61 insertions(+), 8 deletions(-)

diff --git a/backend/internal/adapters/runtime/tmux/commands.go b/backend/internal/adapters/runtime/tmux/commands.go
index 6d93d330..75c24bf2 100644
--- a/backend/internal/adapters/runtime/tmux/commands.go
+++ b/backend/internal/adapters/runtime/tmux/commands.go
@@ -72,10 +72,19 @@ func sendKeysLiteralArgs(id, chunk string) []string {
 	return []string{"send-keys", "-t", id, "-l", chunk}
 }
 
-// sendEnterArgs builds args for `tmux send-keys -t <id> Enter` to submit the
+// sendEnterArgs builds args for `tmux send-keys -t <id> C-m` to submit the
 // queued input.
 func sendEnterArgs(id string) []string {
-	return []string{"send-keys", "-t", id, "Enter"}
+	// C-m is the terminal carriage-return sequence expected by interactive
+	// agent TUIs. tmux's named Enter key can leave Codex's pasted prompt as an
+	// unsubmitted draft, while C-m submits it consistently.
+	return []string{"send-keys", "-t", id, "C-m"}
+}
+
+// sendLongPasteSubmitArgs first exits Codex's collapsed-paste state without
+// changing the input, then submits with a single carriage return.
+func sendLongPasteSubmitArgs(id string) []string {
+	return []string{"send-keys", "-t", id, "Left", "Right", "C-m"}
 }
 
 // sendInterruptArgs builds args for `tmux send-keys -t <id> C-c` to interrupt
diff --git a/backend/internal/adapters/runtime/tmux/tmux.go b/backend/internal/adapters/runtime/tmux/tmux.go
index b0962b45..39a7783a 100644
--- a/backend/internal/adapters/runtime/tmux/tmux.go
+++ b/backend/internal/adapters/runtime/tmux/tmux.go
@@ -26,7 +26,9 @@ const (
 	// defaultEnterDelay mirrors conpty's ptyInputEnterDelay: a pause after pasting
 	// a non-empty message, before the trailing Enter, so a large multiline paste
 	// does not absorb the Enter and leave the prompt unsubmitted (issue #2342).
-	defaultEnterDelay = 300 * time.Millisecond
+	defaultEnterDelay     = 300 * time.Millisecond
+	longMessageBytes      = 1024
+	longMessageEnterDelay = time.Second
 )
 
 var sessionIDPattern = regexp.MustCompile(`^[a-zA-Z0-9_-]+$`)
@@ -238,22 +240,34 @@ func (r *Runtime) SendMessage(ctx context.Context, handle ports.RuntimeHandle, m
 		// their own timeout instead): abandoning mid-pause would strand an
 		// unsubmitted draft that a retried send would then double-paste.
 		var cancel context.CancelFunc
-		enterCtx, cancel = context.WithTimeout(context.WithoutCancel(ctx), r.enterDelay+5*time.Second)
+		enterDelay := r.enterDelayFor(message)
+		enterCtx, cancel = context.WithTimeout(context.WithoutCancel(ctx), enterDelay+5*time.Second)
 		defer cancel()
-		if r.enterDelay > 0 {
+		if enterDelay > 0 {
 			select {
 			case <-enterCtx.Done():
 				return enterCtx.Err()
-			case <-time.After(r.enterDelay):
+			case <-time.After(enterDelay):
 			}
 		}
 	}
-	if _, err := r.run(enterCtx, sendEnterArgs(id)...); err != nil {
+	submitArgs := sendEnterArgs(id)
+	if len(message) >= longMessageBytes {
+		submitArgs = sendLongPasteSubmitArgs(id)
+	}
+	if _, err := r.run(enterCtx, submitArgs...); err != nil {
 		return fmt.Errorf("tmux runtime: send enter %s: %w", id, err)
 	}
 	return nil
 }
 
+func (r *Runtime) enterDelayFor(message string) time.Duration {
+	if len(message) >= longMessageBytes && r.enterDelay == defaultEnterDelay {
+		return longMessageEnterDelay
+	}
+	return r.enterDelay
+}
+
 // Interrupt sends Ctrl-C to the foreground process without destroying the tmux
 // session, keeping the terminal available for inspection and reuse.
 func (r *Runtime) Interrupt(ctx context.Context, handle ports.RuntimeHandle) error {
diff --git a/backend/internal/adapters/runtime/tmux/tmux_test.go b/backend/internal/adapters/runtime/tmux/tmux_test.go
index 3cef26f6..b287166b 100644
--- a/backend/internal/adapters/runtime/tmux/tmux_test.go
+++ b/backend/internal/adapters/runtime/tmux/tmux_test.go
@@ -95,9 +95,12 @@ func TestCommandBuilders(t *testing.T) {
 	if got, want := sendKeysLiteralArgs("sess-1", "hello"), []string{"send-keys", "-t", "sess-1", "-l", "hello"}; !reflect.DeepEqual(got, want) {
 		t.Fatalf("sendKeysLiteralArgs = %#v, want %#v", got, want)
 	}
-	if got, want := sendEnterArgs("sess-1"), []string{"send-keys", "-t", "sess-1", "Enter"}; !reflect.DeepEqual(got, want) {
+	if got, want := sendEnterArgs("sess-1"), []string{"send-keys", "-t", "sess-1", "C-m"}; !reflect.DeepEqual(got, want) {
 		t.Fatalf("sendEnterArgs = %#v, want %#v", got, want)
 	}
+	if got, want := sendLongPasteSubmitArgs("sess-1"), []string{"send-keys", "-t", "sess-1", "Left", "Right", "C-m"}; !reflect.DeepEqual(got, want) {
+		t.Fatalf("sendLongPasteSubmitArgs = %#v, want %#v", got, want)
+	}
 	if got, want := sendInterruptArgs("sess-1"), []string{"send-keys", "-t", "sess-1", "C-c"}; !reflect.DeepEqual(got, want) {
 		t.Fatalf("sendInterruptArgs = %#v, want %#v", got, want)
 	}
@@ -500,6 +503,17 @@ func TestSendMessageChunksAndSendsEnter(t *testing.T) {
 	}
 }
 
+func TestSendMessageCommitsLongPasteBeforeSubmit(t *testing.T) {
+	r, fr := newTestRuntime(0)
+	message := strings.Repeat("x", longMessageBytes)
+	if err := r.SendMessage(context.Background(), ports.RuntimeHandle{ID: "sess-1"}, message); err != nil {
+		t.Fatalf("SendMessage: %v", err)
+	}
+	if got, want := fr.calls[len(fr.calls)-1].args, sendLongPasteSubmitArgs("sess-1"); !reflect.DeepEqual(got, want) {
+		t.Fatalf("long paste submit args = %#v, want %#v", got, want)
+	}
+}
+
 func TestSendMessageUsesLiteralFlag(t *testing.T) {
 	r, fr := newTestRuntime(0)
 	if err := r.SendMessage(context.Background(), ports.RuntimeHandle{ID: "sess-1"}, "Enter"); err != nil {
@@ -566,6 +580,22 @@ func TestSendMessageDelaysBeforeEnter(t *testing.T) {
 	}
 }
 
+func TestEnterDelayForLongMessages(t *testing.T) {
+	r := New(Options{Binary: "tmux-test", Shell: "/bin/sh"})
+	if got := r.enterDelayFor(strings.Repeat("x", longMessageBytes-1)); got != defaultEnterDelay {
+		t.Fatalf("short message delay = %s, want %s", got, defaultEnterDelay)
+	}
+	if got := r.enterDelayFor(strings.Repeat("x", longMessageBytes)); got != longMessageEnterDelay {
+		t.Fatalf("long message delay = %s, want %s", got, longMessageEnterDelay)
+	}
+
+	custom := 25 * time.Millisecond
+	r = New(Options{Binary: "tmux-test", Shell: "/bin/sh", EnterDelay: custom})
+	if got := r.enterDelayFor(strings.Repeat("x", longMessageBytes)); got != custom {
+		t.Fatalf("custom long-message delay = %s, want %s", got, custom)
+	}
+}
+
 // TestSendMessageEnterSurvivesCallerCancel pins the detached-Enter contract:
 // once the chunks are pasted, a caller cancellation landing in the pre-Enter
 // pause must NOT abandon the send — the pasted draft would sit unsubmitted and
